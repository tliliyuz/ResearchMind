# ── 应用 ──
APP_NAME=ResearchMind
DEBUG=true
ENV=development

# ── MySQL ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=researchmind
MYSQL_PASSWORD=<your-password>
MYSQL_DATABASE=researchmind

# ── Redis / Celery ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM (DeepSeek) ──
LLM_API_KEY=<your-deepseek-api-key>
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
# LLM_PLANNING_MODEL=deepseek-v4-pro  # [v2] 分级模型
# LLM_FLASH_MODEL=deepseek-v4-flash   # [v2] 轻量模型

# ── 搜索 ──
TAVILY_API_KEY=<your-tavily-api-key>

# ── JWT ──
JWT_SECRET_KEY=<generate-random-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_SECRET_KEY=<generate-another-random-secret>

# ── 可观测性 / Prometheus ──
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
METRICS_QUEUE_REFRESH_INTERVAL=15
METRICS_WORKER_REFRESH_INTERVAL=15
METRICS_WORKER_PING_TIMEOUT=5.0

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── 部署 / Docker Compose（生产环境建议覆盖）──
ENV=production
LOG_LEVEL=INFO
TZ=UTC

# Uvicorn
UVICORN_WORKERS=1

# Celery Worker / Beat
CELERY_LOG_LEVEL=info
CELERY_WORKER_POOL=solo
CELERY_WORKER_CONCURRENCY=1
CELERY_BEAT_ENABLED=true

# 数据 TTL 清理
CLEANUP_TASK_MAX_AGE_DAYS=30
CLEANUP_REFRESH_TOKEN_MAX_AGE_DAYS=90

# Prometheus（多进程聚合目录，容器内使用）
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
PROMETHEUS_RETENTION_TIME=30d

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<change-me>
GRAFANA_ROOT_URL=http://localhost:3000

# MySQL root 密码（仅 docker-compose 健康检查需要）
MYSQL_ROOT_PASSWORD=<your-root-password>

# 限流（生产建议启用）
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
